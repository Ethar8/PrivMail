{
  "name": "privmail-backend",
  "version": "1.0.0",
  "description": "PrivMail Backend – Eigener Mail-Server mit SMTP/IMAP",
  "license": "MIT",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && npm run copy:assets",
    "copy:assets": "node -e \"const fs=require('fs');const s='src/database/migrations';const d='dist/database/migrations';fs.mkdirSync(d,{recursive:true});for(const f of fs.readdirSync(s))if(f.endsWith('.sql'))fs.copyFileSync(s+'/'+f,d+'/'+f)\"",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test:e2e-sso": "node --require ts-node/register/transpile-only src/test/e2e/sso-suite.e2e.ts"
  },
  "dependencies": {
    "@noble/post-quantum": "^0.6.1",
    "@simplewebauthn/server": "^9.0.3",
    "bcryptjs": "^2.4.3",
    "connect-pg-simple": "^9.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "oidc-provider": "^8.8.1",
    "openpgp": "^5.11.2",
    "pg": "^8.12.0",
    "winston": "^3.14.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.4.0",
    "@typescript-eslint/parser": "^8.4.0",
    "embedded-postgres": "^18.4.0-beta.17",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}

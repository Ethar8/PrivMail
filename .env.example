# PrivMail Suite – Umgebungsvariablen (Beispiel)
# Kopiere nach .env ODER nutze: ./scripts/setup-wizard.sh
# Ersetze alle <DEINE-…>-Platzhalter. Secrets niemals von Hand erfinden —
# generate-secrets.sh / setup-wizard.sh erzeugen sie automatisch.

# --- Pflicht: deine Domain ---
DOMAIN=<DEINE-DOMAIN>
VAULT_HOST=vault.<DEINE-DOMAIN>
PHOTOS_HOST=photos.<DEINE-DOMAIN>

# PostgreSQL (Passwort wird vom Wizard gesetzt, falls Platzhalter)
DB_USER=privmail
DB_PASSWORD=change-me
DATABASE_URL=postgresql://privmail:change-me@postgres:5432/privmail

# Sicherheit (Platzhalter → werden ersetzt)
JWT_SECRET=change-me
SESSION_SECRET=change-me

# Werden aus DOMAIN/Hosts abgeleitet, falls leer
CORS_ORIGINS=
OIDC_ISSUER=
OIDC_VAULTWARDEN_CLIENT_ID=vaultwarden
OIDC_VAULTWARDEN_CLIENT_SECRET=change-me
OIDC_IMMICH_CLIENT_ID=immich
OIDC_IMMICH_CLIENT_SECRET=change-me

VAULTWARDEN_ADMIN_TOKEN=
VAULTWARDEN_SIGNUPS_ALLOWED=false

IMMICH_VERSION=v3
IMMICH_UPLOAD_LOCATION=./data/immich/library
IMMICH_DB_DATA_LOCATION=./data/immich/postgres
IMMICH_DB_USERNAME=postgres
IMMICH_DB_PASSWORD=change-me
IMMICH_DB_DATABASE_NAME=immich

SMTP_PORT=2525
IMAP_PORT=2143
API_PORT=3000

# Ausgehende DKIM-Signierung (nach ./infrastructure/scripts/setup-dkim.sh)
DKIM_SELECTOR=privmail
DKIM_PRIVATE_KEY_PATH=/etc/privmail/dkim/privmail.private.pem

# Backend TLS (gleiche Dateien wie Nginx unter infrastructure/nginx/ssl/)
TLS_CERT_PATH=/etc/privmail/ssl/fullchain.pem
TLS_KEY_PATH=/etc/privmail/ssl/privkey.pem

NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_MAIL_URL=
NEXT_PUBLIC_VAULT_URL=
NEXT_PUBLIC_PHOTOS_URL=

NODE_ENV=production

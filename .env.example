# PrivMail Umgebungsvariablen
# Kopiere diese Datei nach .env und passe die Werte an.

# Domain
DOMAIN=mail.ihre-domain.de

# PostgreSQL
DB_USER=privmail
DB_PASSWORD=change-me
DATABASE_URL=postgresql://privmail:change-me@postgres:5432/privmail

# Sicherheit
JWT_SECRET=change-me-to-a-long-random-string
SESSION_SECRET=change-me-to-another-long-random-string

# Ports
SMTP_PORT=2525
IMAP_PORT=2143
API_PORT=3000
HTTP_PORT=8080
HTTPS_PORT=8443

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3000

# Umgebung
NODE_ENV=production
